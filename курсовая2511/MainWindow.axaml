<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:курсовая2511"
        x:Class="курсовая2511.MainWindow"
        x:DataType="vm:AuthViewModel"
        Title="TechAccounting — Система учёта техники ИТ"
        Width="1150" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

	<Window.Styles>
		<Style Selector="Button.menu-btn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="CornerRadius" Value="5"/>
		</Style>

		<Style Selector="TextBox.auth-input">
			<Setter Property="Background" Value="#3A3A3C"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="CaretBrush" Value="White"/>
			<Setter Property="BorderBrush" Value="#007ACC"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height" Value="35"/>
			<Setter Property="Padding" Value="8,5"/>
			<Setter Property="CornerRadius" Value="3"/>
			<Setter Property="IsVisible" Value="True"/>
			<Setter Property="IsEnabled" Value="True"/>
			<Setter Property="IsReadOnly" Value="False"/>
			<Setter Property="IsHitTestVisible" Value="True"/>
		</Style>

		<Style Selector="ComboBox.auth-input">
			<Setter Property="Background" Value="#3A3A3C"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#007ACC"/>
			<Setter Property="Height" Value="35"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>
	</Window.Styles>

	<Grid>

		<Border IsVisible="{Binding !IsLoggedIn}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Padding="30" Background="#252526" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1">
			<Grid>
				<StackPanel Spacing="15" IsVisible="{Binding !IsRegisterMode}">
					<TextBlock Text="Вход в систему" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
					<StackPanel Spacing="5">
						<TextBlock Text="Логин:" Foreground="#858585" FontSize="12"/>
						<TextBox Classes="auth-input" Text="{Binding Username, Mode=TwoWay}" Watermark="Введите логин..."/>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Пароль:" Foreground="#858585" FontSize="12"/>
						<TextBox Classes="auth-input" Text="{Binding Password, Mode=TwoWay}" PasswordChar="*" Watermark="Введите пароль..."/>
					</StackPanel>
					<TextBlock Text="{Binding StatusMessage}" Foreground="#FF453A" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap" MinHeight="20"/>
					<Button Content="Войти" Command="{Binding LoginCommand}" Background="#007ACC" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" FontWeight="Bold" CornerRadius="5" Height="40"/>
					<Button Content="Создать аккаунт" Command="{Binding ToggleModeCommand}" Background="Transparent" Foreground="#858585" HorizontalAlignment="Center" FontSize="12"/>
				</StackPanel>

				<StackPanel Spacing="15" IsVisible="{Binding IsRegisterMode}">
					<TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
					<StackPanel Spacing="5">
						<TextBlock Text="Электронная почта:" Foreground="#858585" FontSize="12"/>
						<TextBox Classes="auth-input" Text="{Binding RegEmail, Mode=TwoWay}" Watermark="example@mail.com"/>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Логин:" Foreground="#858585" FontSize="12"/>
						<TextBox Classes="auth-input" Text="{Binding RegUsername, Mode=TwoWay}" Watermark="Придумайте логин..."/>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Пароль:" Foreground="#858585" FontSize="12"/>
						<TextBox Classes="auth-input" Text="{Binding RegPassword, Mode=TwoWay}" PasswordChar="*" Watermark="Придумайте пароль..."/>
					</StackPanel>
					<TextBlock Text="{Binding StatusMessage}" Foreground="#4CD964" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap" MinHeight="20"/>
					<Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" Background="#4CD964" Foreground="Black" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" FontWeight="Bold" CornerRadius="5" Height="40"/>
					<Button Content="Уже есть аккаунт? Войти" Command="{Binding ToggleModeCommand}" Background="Transparent" Foreground="#858585" HorizontalAlignment="Center" FontSize="12"/>
				</StackPanel>
			</Grid>
		</Border>


		<Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="240, *">
			<Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
				<Grid RowDefinitions="Auto, *, Auto">
					<StackPanel Grid.Row="0" Margin="20,25,20,25" Orientation="Horizontal" Spacing="10">
						<Border Background="#007ACC" CornerRadius="4" Width="32" Height="32">
							<TextBlock Text="💻" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
						</Border>
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="TechAccounting" FontWeight="Bold" Foreground="White" FontSize="14"/>
							<TextBlock Text="Администратор" Foreground="#858585" FontSize="10"/>
						</StackPanel>
					</StackPanel>

					<StackPanel Grid.Row="1" Spacing="6" Margin="10,0">
						<Button Classes="menu-btn" Command="{Binding SelectEquipmentTabCommand}">
							<StackPanel Orientation="Horizontal" Spacing="12" Margin="10,0">
								<TextBlock Text="📋" VerticalAlignment="Center"/>
								<TextBlock Text="Реестр техники" Foreground="White" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
						<Button Classes="menu-btn" Command="{Binding SelectAssignmentsTabCommand}">
							<StackPanel Orientation="Horizontal" Spacing="12" Margin="10,0">
								<TextBlock Text="🤝" VerticalAlignment="Center"/>
								<TextBlock Text="Выдача / Возврат" Foreground="White" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
						<Button Classes="menu-btn" Command="{Binding SelectReportsTabCommand}">
							<StackPanel Orientation="Horizontal" Spacing="12" Margin="10,0">
								<TextBlock Text="📊" VerticalAlignment="Center"/>
								<TextBlock Text="Аналитика и отчёты" Foreground="White" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
						<Button Classes="menu-btn" Command="{Binding SelectEmployeesTabCommand}">
							<StackPanel Orientation="Horizontal" Spacing="12" Margin="10,0">
								<TextBlock Text="👥" VerticalAlignment="Center"/>
								<TextBlock Text="Сотрудники" Foreground="White" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
					</StackPanel>

					<Button Grid.Row="2" Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch" Height="40" Margin="10,20" Background="#3A3A3C" CornerRadius="5">
						<StackPanel Orientation="Horizontal" Spacing="12" Margin="10,0" HorizontalAlignment="Center">
							<TextBlock Text="🚪" VerticalAlignment="Center"/>
							<TextBlock Text="Выйти" Foreground="#FF453A" VerticalAlignment="Center" FontWeight="Bold"/>
						</StackPanel>
					</Button>
				</Grid>
			</Border>

			<Grid Grid.Column="1" RowDefinitions="Auto, *">
				<Border Grid.Row="0" Background="#1E1E1E" Padding="20">
					<Grid ColumnDefinitions="*, *, *">
						<Border Grid.Column="0" Background="#2D2D30" CornerRadius="8" Margin="0,0,10,0" Padding="15,12">
							<StackPanel>
								<TextBlock Text="НА СКЛАДЕ" FontSize="11" Foreground="#858585" FontWeight="Bold"/>
								<TextBlock Text="{Binding InStockCount}" FontSize="24" FontWeight="Bold" Foreground="#4CD964" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
						<Border Grid.Column="1" Background="#2D2D30" CornerRadius="8" Margin="10,0" Padding="15,12">
							<StackPanel>
								<TextBlock Text="ВЫДАНО СОТРУДНИКАМ" FontSize="11" Foreground="#858585" FontWeight="Bold"/>
								<TextBlock Text="{Binding IssuedCount}" FontSize="24" FontWeight="Bold" Foreground="#2196F3" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
						<Border Grid.Column="2" Background="#2D2D30" CornerRadius="8" Margin="10,0,0,0" Padding="15,12">
							<StackPanel>
								<TextBlock Text="В РЕМОНТЕ" FontSize="11" Foreground="#858585" FontWeight="Bold"/>
								<TextBlock Text="{Binding UnderRepairCount}" FontSize="24" FontWeight="Bold" Foreground="#FF9500" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
					</Grid>
				</Border>

				<Border Grid.Row="1" Background="#121212" CornerRadius="12,0,0,0" Padding="20">
					<Carousel SelectedIndex="{Binding CurrentTab}">

					
						<ScrollViewer>
							<Grid ColumnDefinitions="420, *">
								<StackPanel Grid.Column="0" Spacing="10" Margin="0,0,20,0">
									<TextBlock Text="Добавить технику" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
									<Border Background="#1E1E1E" CornerRadius="8" Padding="20">
										<StackPanel Spacing="10">
											<TextBlock Text="Тип техники:" Foreground="#858585" FontSize="12"/>
											<ComboBox Classes="auth-input" ItemsSource="{Binding EquipmentTypes}" SelectedItem="{Binding SelectedEquipmentType}" PlaceholderText="Выберите тип...">
												<ComboBox.ItemTemplate>
													<DataTemplate>
														<TextBlock Text="{Binding Description}"/>
													</DataTemplate>
												</ComboBox.ItemTemplate>
											</ComboBox>

											<TextBlock Text="Название:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentName}" Watermark="Например: Dell Latitude 5420"/>

											<TextBlock Text="Серийный номер:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentSerialNumber}" Watermark="Уникальный, обязательно"/>

											<TextBlock Text="Инвентарный номер:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentInventoryNumber}" Watermark="Например: INV-00123"/>

											<TextBlock Text="Производитель:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentManufacturer}" Watermark="Dell, HP, Lenovo..."/>

											<TextBlock Text="Модель:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentModel}" Watermark="Latitude 5420"/>

											<TextBlock Text="Расположение:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentLocation}" Watermark="Кабинет 305"/>

											<TextBlock Text="Цена (руб.):" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding NewEquipmentPrice}" Watermark="55000"/>

											<TextBlock Text="{Binding AddEquipmentStatusMessage}" Foreground="#4CD964" FontSize="12" TextWrapping="Wrap" MinHeight="20"/>

											<Button Content="Добавить технику" Command="{Binding AddEquipmentCommand}" Background="#4CD964" Foreground="Black" Height="40" HorizontalContentAlignment="Center" FontWeight="Bold" CornerRadius="5"/>
										</StackPanel>
									</Border>
								</StackPanel>

								<Grid Grid.Column="1" RowDefinitions="Auto, *">
									<TextBlock Grid.Row="0" Text="Список всей техники предприятия" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
									<ListBox Grid.Row="1" ItemsSource="{Binding EquipmentItems}" Background="#1E1E1E">
										<ListBox.ItemTemplate>
											<DataTemplate>
												<StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4">
													<TextBlock Text="{Binding InventoryNumber}" Foreground="Gray"/>
													<TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
													<TextBlock Text="{Binding Status}" Foreground="#4CD964"/>
												</StackPanel>
											</DataTemplate>
										</ListBox.ItemTemplate>
									</ListBox>
								</Grid>
							</Grid>
						</ScrollViewer>

				
						<ScrollViewer>
							<StackPanel Spacing="20">
								<Grid RowDefinitions="Auto, *">
									<TextBlock Grid.Row="0" Text="Регистрация выдачи техники сотрудникам" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
									<Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="20">
										<StackPanel Spacing="10" Width="420" HorizontalAlignment="Left">
											<TextBlock Text="Оформить выдачу техники" FontSize="14" FontWeight="Bold" Foreground="White"/>

											<TextBlock Text="Сотрудник:" Foreground="#858585" FontSize="12"/>
											<ComboBox Classes="auth-input" ItemsSource="{Binding EmployeeItems}" SelectedItem="{Binding SelectedEmployee}" PlaceholderText="Выберите сотрудника...">
												<ComboBox.ItemTemplate>
													<DataTemplate>
														<StackPanel Orientation="Horizontal" Spacing="6">
															<TextBlock Text="{Binding LastName}"/>
															<TextBlock Text="{Binding FirstName}"/>
															<TextBlock Text="—" Foreground="#858585"/>
															<TextBlock Text="{Binding Position}" Foreground="#858585"/>
														</StackPanel>
													</DataTemplate>
												</ComboBox.ItemTemplate>
											</ComboBox>

											<TextBlock Text="Техника (только свободная):" Foreground="#858585" FontSize="12"/>
											<ComboBox Classes="auth-input" ItemsSource="{Binding AvailableEquipmentItems}" SelectedItem="{Binding SelectedEquipmentForIssue}" PlaceholderText="Выберите технику...">
												<ComboBox.ItemTemplate>
													<DataTemplate>
														<TextBlock Text="{Binding Name}"/>
													</DataTemplate>
												</ComboBox.ItemTemplate>
											</ComboBox>

											<TextBlock Text="Состояние при выдаче:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding IssueCondition}" Watermark="Например: Норма"/>

											<TextBlock Text="{Binding AssignmentStatusMessage}" Foreground="#4CD964" FontSize="12" TextWrapping="Wrap" MinHeight="20"/>

											<Button Content="Зафиксировать выдачу" Command="{Binding AssignEquipmentCommand}" Background="#2196F3" Foreground="White" Height="40" HorizontalContentAlignment="Center" FontWeight="Bold" CornerRadius="5"/>
										</StackPanel>
									</Border>
								</Grid>

								<Grid RowDefinitions="Auto, *">
									<TextBlock Grid.Row="0" Text="Приём техники обратно на склад" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
									<Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="20">
										<StackPanel Spacing="10" Width="420" HorizontalAlignment="Left">
											<TextBlock Text="Активные выдачи:" Foreground="#858585" FontSize="12"/>
											<ComboBox Classes="auth-input" ItemsSource="{Binding ActiveAssignments}" SelectedItem="{Binding SelectedActiveAssignment}" PlaceholderText="Выберите выдачу для возврата...">
												<ComboBox.ItemTemplate>
													<DataTemplate>
														<TextBlock Text="{Binding DisplayText}"/>
													</DataTemplate>
												</ComboBox.ItemTemplate>
											</ComboBox>

											<TextBlock Text="Состояние при возврате:" Foreground="#858585" FontSize="12"/>
											<TextBox Classes="auth-input" Text="{Binding ReturnCondition}" Watermark="Например: Норма"/>

											<TextBlock Text="{Binding ReturnStatusMessage}" Foreground="#4CD964" FontSize="12" TextWrapping="Wrap" MinHeight="20"/>

											<Button Content="Принять на склад" Command="{Binding ReturnEquipmentCommand}" Background="#FF9500" Foreground="Black" Height="40" HorizontalContentAlignment="Center" FontWeight="Bold" CornerRadius="5"/>
										</StackPanel>
									</Border>
								</Grid>
							</StackPanel>
						</ScrollViewer>

				
						<ScrollViewer>
							<StackPanel Spacing="20">

								<Grid ColumnDefinitions="*, *">
							
									<Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="0,0,10,0">
										<StackPanel Spacing="10">
											<TextBlock Text="Отправить технику в ремонт" FontSize="14" FontWeight="Bold" Foreground="White"/>
											<ComboBox Classes="auth-input" ItemsSource="{Binding RepairableEquipmentItems}" SelectedItem="{Binding SelectedEquipmentForRepair}" PlaceholderText="Выберите технику...">
												<ComboBox.ItemTemplate>
													<DataTemplate>
														<StackPanel Orientation="Horizontal" Spacing="8">
															<TextBlock Text="{Binding Name}"/>
															<TextBlock Text="{Binding Status}" Foreground="#858585"/>
														</StackPanel>
													</DataTemplate>
												</ComboBox.ItemTemplate>
											</ComboBox>
											<Button Content="Отправить в ремонт" Command="{Binding SendToRepairCommand}" Background="#FF9500" Foreground="Black" Height="38" HorizontalContentAlignment="Center" FontWeight="Bold" CornerRadius="5"/>
										</StackPanel>
									</Border>

									<Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="20" Margin="10,0,0,0">
										<StackPanel Spacing="10">
											<TextBlock Text="Вернуть технику из ремонта" FontSize="14" FontWeight="Bold" Foreground="White"/>
											<ComboBox Classes="auth-input" ItemsSource="{Binding UnderRepairEquipmentItems}" SelectedItem="{Binding SelectedEquipmentForRepairReturn}" PlaceholderText="Выберите технику...">
												<ComboBox.ItemTemplate>
													<DataTemplate>
														<TextBlock Text="{Binding Name}"/>
													</DataTemplate>
												</ComboBox.ItemTemplate>
											</ComboBox>
											<Button Content="Вернуть на склад" Command="{Binding ReturnFromRepairCommand}" Background="#4CD964" Foreground="Black" Height="38" HorizontalContentAlignment="Center" FontWeight="Bold" CornerRadius="5"/>
										</StackPanel>
									</Border>
								</Grid>

								<TextBlock Text="{Binding RepairStatusMessage}" Foreground="#4CD964" FontSize="12" TextWrapping="Wrap" MinHeight="20"/>

								<Grid RowDefinitions="Auto, *">
									<TextBlock Grid.Row="0" Text="История перемещений техники" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
									<Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="15" MinHeight="250">
										<ListBox ItemsSource="{Binding HistoryItems}" Background="Transparent">
											<ListBox.ItemTemplate>
												<DataTemplate>
													<TextBlock Text="{Binding DisplayText}" Foreground="White" TextWrapping="Wrap" Margin="0,4"/>
												</DataTemplate>
											</ListBox.ItemTemplate>
										</ListBox>
									</Border>
								</Grid>

							</StackPanel>
						</ScrollViewer>

						<Grid ColumnDefinitions="420, *">
							<StackPanel Grid.Column="0" Spacing="10" Margin="0,0,20,0">
								<TextBlock Text="Добавить сотрудника" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
								<Border Background="#1E1E1E" CornerRadius="8" Padding="20">
									<StackPanel Spacing="10">
										<TextBlock Text="Имя:" Foreground="#858585" FontSize="12"/>
										<TextBox Classes="auth-input" Text="{Binding NewEmployeeFirstName}" Watermark="Иван"/>

										<TextBlock Text="Фамилия:" Foreground="#858585" FontSize="12"/>
										<TextBox Classes="auth-input" Text="{Binding NewEmployeeLastName}" Watermark="Иванов"/>

										<TextBlock Text="Отдел:" Foreground="#858585" FontSize="12"/>
										<TextBox Classes="auth-input" Text="{Binding NewEmployeeDepartment}" Watermark="IT-отдел"/>

										<TextBlock Text="Должность:" Foreground="#858585" FontSize="12"/>
										<TextBox Classes="auth-input" Text="{Binding NewEmployeePosition}" Watermark="Инженер"/>

										<TextBlock Text="Email:" Foreground="#858585" FontSize="12"/>
										<TextBox Classes="auth-input" Text="{Binding NewEmployeeEmail}" Watermark="ivanov@company.ru"/>

										<TextBlock Text="Телефон:" Foreground="#858585" FontSize="12"/>
										<TextBox Classes="auth-input" Text="{Binding NewEmployeePhone}" Watermark="+7 900 000-00-00"/>

										<TextBlock Text="{Binding AddEmployeeStatusMessage}" Foreground="#4CD964" FontSize="12" TextWrapping="Wrap" MinHeight="20"/>

										<Button Content="Добавить сотрудника" Command="{Binding AddEmployeeCommand}" Background="#4CD964" Foreground="Black" Height="40" HorizontalContentAlignment="Center" FontWeight="Bold" CornerRadius="5"/>
									</StackPanel>
								</Border>
							</StackPanel>

							<Grid Grid.Column="1" RowDefinitions="Auto, *">
								<TextBlock Grid.Row="0" Text="Список сотрудников" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
								<ListBox Grid.Row="1" ItemsSource="{Binding EmployeeItems}" Background="#1E1E1E">
									<ListBox.ItemTemplate>
										<DataTemplate>
											<StackPanel Orientation="Horizontal" Spacing="15" Margin="0,4">
												<TextBlock Text="{Binding LastName}" Foreground="White" FontWeight="Bold"/>
												<TextBlock Text="{Binding FirstName}" Foreground="White"/>
												<TextBlock Text="{Binding Department}" Foreground="#858585"/>
												<TextBlock Text="{Binding Position}" Foreground="#4CD964"/>
											</StackPanel>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</Grid>
						</Grid>

					</Carousel>
				</Border>
			</Grid>
		</Grid>
	</Grid>
</Window>
